# ============================================
# PropertyLegal App - Environment Variables
# ============================================

# Claude AI API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Maps API Key (get from console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase (auto-populated by FlutterFire CLI)
# Run: flutterfire configure

# Razorpay (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Karnataka Bhoomi API (Karnataka govt portal)
BHOOMI_BASE_URL=https://bhoomi.karnataka.gov.in
BHOOMI_API_KEY=your_bhoomi_api_key_here

# RERA Karnataka
RERA_BASE_URL=https://rera.karnataka.gov.in

# App Config
APP_NAME=PropertyLegal
APP_ENV=development
REPORT_PRICE_INR=99
SUBSCRIPTION_PRICE_INR=999
